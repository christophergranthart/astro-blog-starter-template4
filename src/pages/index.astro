<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Coast Home Care Services | Peace of Mind</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.min.css">
    <style>
        :root {
            --brand-pink: #E6007E;
            --brand-blue: #32B5E5;
            --brand-navy: #1A2B49;
            --sand: #F4F1EA;
            --white: #ffffff;
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brand-navy);
            background-color: var(--white);
            line-height: 1.6;
        }

        /* NEW HEADER LAYOUT (Astro Blog Style) */
        header {
            display: grid;
            grid-template-columns: 1fr auto 1fr; /* Left, Center, Right */
            align-items: center;
            padding: 10px 5%;
            background: white;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* 1. Left: Logo & Registration */
        .header-left {
            display: flex;
            flex-direction: column;
        }
        .logo-container {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-small { height: 45px; width: auto; border-radius: 50%; }
        .logo-text { font-weight: 700; font-size: 0.9rem; line-height: 1; }
        .reg-mini { font-size: 0.6rem; opacity: 0.6; margin-top: 2px; }

        /* 2. Center: Navigation links */
        nav {
            display: flex;
            gap: 25px;
        }
        nav a {
            text-decoration: none;
            color: var(--brand-navy);
            font-size: 0.9rem;
            font-weight: 700;
            position: relative;
            padding: 5px 0;
        }
        /* The blue underline effect from your screenshot */
        nav a:hover::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--brand-blue);
        }

        /* 3. Right: Contact Icons */
        .header-right {
            display: flex;
            justify-content: flex-end;
            gap: 20px;
            font-size: 1.2rem;
        }
        .header-right a { color: var(--brand-navy); transition: 0.3s; }
        .header-right a:hover { color: var(--brand-blue); }

        /* HERO SECTION */
        .hero {
            display: flex;
            align-items: center;
            padding: 60px 8%;
            background: linear-gradient(135deg, #fff 60%, var(--sand) 100%);
        }
        .hero-text { flex: 1; max-width: 550px; }
        .hero-text h1 { font-size: 2.8rem; line-height: 1.1; margin-bottom: 15px; }
        .hero-text h1 span { color: var(--brand-pink); }
        .hero-text p { font-size: 1.1rem; margin-bottom: 30px; }

        .hero-art { flex: 1; display: flex; justify-content: center; }
        .hero-art img { width: 80%; max-width: 400px; border-radius: 50%; }

        /* SERVICE PILLS */
        .services { padding: 60px 8%; text-align: center; }
        .service-grid {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 40px;
        }
        .card {
            background: var(--sand);
            padding: 15px 30px;
            border-radius: 100px; /* Pill shape */
            border: 1px solid transparent;
            font-weight: 700;
            font-size: 0.9rem;
            transition: 0.3s;
            cursor: default;
        }
        .card:hover { border-color: var(--brand-blue); background: white; transform: scale(1.05); }

        /* FOOTER */
        footer {
            background: var(--brand-navy);
            color: white;
            padding: 40px 8%;
            text-align: center;
        }
        .footer-eval-btn {
            background: var(--brand-pink);
            color: white;
            padding: 15px 30px;
            border-radius: 50px;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 30px;
            font-weight: 700;
        }

        @media (max-width: 850px) {
            header { grid-template-columns: 1fr; gap: 15px; text-align: center; }
            .header-left, .header-right { justify-content: center; }
            .hero { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-left">
            <div class="logo-container">
                <img src="img/West CoastArtisticBanner.jpg" alt="Logo" class="logo-small">
                <div class="logo-text">WEST COAST<br>HOMECARE</div>
            </div>
            <span class="reg-mini">REG: 2024/129640/07</span>
        </div>

        <nav>
            <a href="#">Home</a>
            <a href="#">Services</a>
            <a href="#">About</a>
            <a href="#">Contact</a>
        </nav>

        <div class="header-right">
            <a href="tel:0621247451" title="Call Nadine"><i class="fa-solid fa-phone"></i></a>
            <a href="mailto:info@westcoasthomecareservices.co.za" title="Email Us"><i class="fa-solid fa-envelope"></i></a>
            <a href="#" title="WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Giving you <br><span>Peace of Mind.</span></h1>
            <p>Taking Home Based Services To The Next Level. We provide day & night care, meal prep, and specialized frail care for your loved ones.</p>
            <a href="tel:0621247451" class="footer-eval-btn">FREE HOME EVALUATION</a>
        </div>
        <div class="hero-art">
            <img src="img/West CoastArtisticBanner.jpg" alt="West Coast Care Banner">
        </div>
    </section>

    <section class="services">
        <h2>Our Home Care Services</h2>
        <div class="service-grid">
            <div class="card">Day & Night Care</div>
            <div class="card">Meal Preparation</div>
            <div class="card">Housekeeping</div>
            <div class="card">Medication Reminders</div>
            <div class="card">Hygiene Assistance</div>
            <div class="card">Dementia Care</div>
            <div class="card">24h Frail Care</div>
            <div class="card">Personalised Service</div>
        </div>
    </section>

    <footer>
        <a href="tel:0621247451" class="footer-eval-btn">CALL NADINE: 062 124 7451</a>
        <p><strong>WEST COAST HOMECARE SERVICES (Pty) Ltd</strong></p>
        <p>info@westcoasthomecareservices.co.za</p>
        <p style="font-size: 0.7rem; opacity: 0.5;">REG: 2024/129640/07</p>
    </footer>

</body>
</html>
