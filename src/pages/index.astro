---
// West Coast Homecare Services - Desktop & Mobile Optimized
const pageTitle = "West Coast Homecare Services | Peace of Mind";
const brandPink = "#E6007E";
const brandBlue = "#32B5E5";
const brandNavy = "#1A2B49";
const sand = "#F4F1EA";

const services = [
  { name: "Day & Night Care", icon: "fa-moon" },
  { name: "Meal Preparation", icon: "fa-utensils" },
  { name: "Light Housekeeping", icon: "fa-broom" },
  { name: "Medication Reminders", icon: "fa-pills" },
  { name: "Hygiene & Dressing", icon: "fa-bath" },
  { name: "Dementia Care", icon: "fa-brain" },
  { name: "24h Frail Care", icon: "fa-heart-pulse" },
  { name: "Companionship", icon: "fa-people-arrows" }
];

const reasons = [
  { title: "Locally Owned", desc: "Community rooted service", icon: "fa-house-chimney-window" },
  { title: "Vetted Staff", desc: "Compassionate & trained", icon: "fa-user-check" },
  { title: "Flexible Plans", desc: "Personalised care plans", icon: "fa-calendar-check" },
  { title: "Wide Coverage", desc: "Saldanha Bay & surrounds", icon: "fa-map-location-dot" }
];

const towns = ["Saldanha Bay", "Vredenburg", "St Helena Bay", "Langebaan", "Velddrif", "Paternoster", "Hopefield"];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style define:vars={{ brandPink, brandBlue, brandNavy, sand }}>
        :root {
            --white: #ffffff;
            --gold: #FFD700;
            --max-width: 1200px; /* The "Sweet Spot" for desktop readability */
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            color: var(--brandNavy);
            background-color: var(--white);
            line-height: 1.6;
            scroll-behavior: smooth;
        }

        h1, h2, h3, .logo-text { font-family: 'Comfortaa', cursive; font-weight: 700; }

        /* --- SHARED LAYOUT UTILITY --- */
        .container {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 0 2rem;
        }

        section { padding: 100px 0; }

        /* --- NAVIGATION --- */
        header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 90px;
            display: flex;
            align-items: center;
        }

        header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .header-left { display: flex; align-items: center; gap: 15px; }
        .logo-small { height: 65px; width: 65px; object-fit: cover; border-radius: 50%; border: 2px solid var(--brandBlue); }
        .logo-text { font-size: 0.9rem; line-height: 1.2; margin: 0; }
        .reg-no { font-size: 0.65rem; opacity: 0.6; display: block; font-family: sans-serif; }

        nav { display: flex; gap: 40px; }
        nav a { text-decoration: none; color: var(--brandNavy); font-size: 1rem; font-weight: 600; transition: 0.3s; position: relative;}
        nav a::after { content: ''; width: 0; height: 2px; background: var(--brandPink); position: absolute; bottom: -5px; left: 0; transition: 0.3s; }
        nav a:hover::after { width: 100%; }

        .header-right { display: flex; gap: 15px; }
        .icon-btn { 
            width: 45px; height: 45px; 
            display: flex; align-items: center; justify-content: center; 
            border-radius: 50%; background: var(--sand); 
            color: var(--brandNavy); transition: 0.3s; text-decoration: none;
        }
        .icon-btn:hover { background: var(--brandPink); color: white; transform: translateY(-3px); }

        /* --- HERO --- */
        .hero {
            background: radial-gradient(circle at top right, var(--sand) 0%, #fff 60%);
            padding: 120px 0 80px 0;
        }
        .hero .container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            gap: 80px;
        }
        .hero-text h1 { font-size: clamp(2.5rem, 4vw, 3.8rem); line-height: 1.1; margin-bottom: 24px; }
        .hero-text span { color: var(--brandPink); }
        .hero-text p { font-size: 1.25rem; color: #444; margin-bottom: 40px; }

        .hero-art { position: relative; }
        .hero-art img { 
            width: 100%; 
            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; 
            box-shadow: 30px 30px 0px var(--sand); 
            animation: morph 8s ease-in-out infinite;
        }

        @keyframes morph {
            0% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
        }

        /* --- FOUNDER SECTION --- */
        .founder-section { background: white; }
        .founder-container { display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: center; }
        .founder-image-wrapper { position: relative; }
        .founder-image { width: 100%; border-radius: 30px; box-shadow: 20px 20px 0px var(--brandBlue); }
        .founder-badge { position: absolute; bottom: -15px; right: -15px; background: var(--brandPink); color: white; padding: 15px 25px; border-radius: 12px; font-weight: bold; }

        /* --- WHY US GRID --- */
        .why-us { background: var(--sand); }
        .reasons-grid { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); /* 4 columns on desktop */
            gap: 30px; 
            margin-top: 60px; 
        }
        .reason-card { 
            padding: 40px 25px; 
            background: #fff; 
            border-radius: 24px; 
            border: 1px solid rgba(0,0,0,0.05); 
            transition: 0.4s;
            text-align: center;
        }
        .reason-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
        .reason-card i { font-size: 2.5rem; color: var(--brandBlue); margin-bottom: 20px; display: block; }

        /* --- SIGNS LIST --- */
        .signs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: center; }
        .signs-list { list-style: none; padding: 0; }
        .signs-list li { margin-bottom: 18px; display: flex; align-items: flex-start; gap: 15px; font-weight: 600; font-size: 1.1rem; }
        .signs-list i { color: var(--brandPink); font-size: 1.3rem; margin-top: 3px; }

        /* --- PILLS --- */
        .service-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; margin-top: 40px; }
        .pill { background: #fff; padding: 15px 30px; border-radius: 100px; display: flex; align-items: center; gap: 12px; font-weight: 600; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid var(--sand); transition: 0.3s;}
        .pill:hover { border-color: var(--brandBlue); transform: scale(1.05); }

        /* --- CTA --- */
        .contact-cta { background: var(--brandBlue); color: #fff; text-align: center; }
        .eval-btn { 
            background: var(--brandPink); 
            color: #fff; 
            padding: 22px 50px; 
            border-radius: 50px; 
            text-decoration: none; 
            font-weight: 700; 
            font-size: 1.1rem;
            display: inline-block; 
            transition: 0.3s; 
            margin-top: 30px;
            box-shadow: 0 10px 20px rgba(230, 0, 126, 0.2);
        }
        .eval-btn:hover { background: var(--brandNavy); transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.2); }

        /* --- RESPONSIVE BREAKPOINTS --- */
        @media (max-width: 1024px) {
            .reasons-grid { grid-template-columns: repeat(2, 1fr); }
            nav { gap: 20px; }
        }

        @media (max-width: 850px) {
            header .container { flex-direction: column; height: auto; padding: 20px; gap: 15px; }
            nav { display: none; }
            .hero .container, .founder-container, .signs-grid { grid-template-columns: 1fr; text-align: center; gap: 50px; }
            .hero-text p { margin: 0 auto 30px; }
            .founder-image-wrapper { max-width: 500px; margin: 0 auto; }
            .reasons-grid { grid-template-columns: 1fr; }
            section { padding: 60px 0; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container">
            <div class="header-left">
                <img src="/logo.jpg" alt="Logo" class="logo-small">
                <div class="logo-details">
                    <p class="logo-text">WEST COAST<br>HOMECARE</p>
                    <span class="reg-no">REG: 2024/129640/07</span>
                </div>
            </div>
            <nav>
                <a href="#">Home</a>
                <a href="#founder">About</a>
                <a href="#services">Services</a>
                <a href="#contact">Contact</a>
            </nav>
            <div class="header-right">
                <a href="tel:0621247451" class="icon-btn" title="Call Us"><i class="fa-solid fa-phone"></i></a>
                <a href="https://wa.me/27621247451" class="icon-btn" target="_blank" title="WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>
            </div>
        </div>
    </header>

    <section class="hero">
        <div class="container">
            <div class="hero-text">
                <h1>Giving you <br><span>Peace of Mind.</span></h1>
                <p>Compassionate, nursing-led home care that treats your loved ones like family. Proudly serving the West Coast community.</p>
                <a href="tel:0621247451" class="eval-btn">FREE HOME EVALUATION</a>
            </div>
            <div class="hero-art">
                <img src="/ArtisticBanner.png" alt="Homecare Services">
            </div>
        </div>
    </section>

    <section class="founder-section" id="founder">
        <div class="container founder-container">
            <div class="founder-image-wrapper">
                <img src="/nadine-saunders.jpg" alt="Nadine Saunders" class="founder-image">
                <div class="founder-badge">Registered Nurse</div>
            </div>
            <div class="founder-text">
                <h2 style="color: var(--brandPink); margin-top:0;">Meet the Founder</h2>
                <h3 style="font-size: 2.2rem; margin-bottom: 20px;">Nadine Saunders</h3>
                <p>With a foundation in professional nursing, I believe that high-quality care starts with empathy. West Coast Homecare Services was born from a desire to provide seniors with the dignity and support they need to thrive at home.</p>
                <p style="border-left: 5px solid var(--brandBlue); padding-left: 25px; font-style: italic; color: #555;">"Every client is unique. We don't just provide a service; we build a relationship based on trust and genuine companionship."</p>
            </div>
        </div>
    </section>

    <section class="why-us">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.5rem;">Why Families Trust Us</h2>
            <div class="reasons-grid">
                {reasons.map((r) => (
                    <div class="reason-card">
                        <i class={`fa-solid ${r.icon}`}></i>
                        <h3>{r.title}</h3>
                        <p>{r.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="signs-section">
        <div class="container signs-grid">
            <div>
                <h2 style="font-size: 2.5rem;">7 Signs Care is Needed</h2>
                <ul class="signs-list">
                    <li><i class="fa-solid fa-check-circle"></i> Struggles with bathing or grooming</li>
                    <li><i class="fa-solid fa-check-circle"></i> Difficulty moving safely around the home</li>
                    <li><i class="fa-solid fa-check-circle"></i> Increased risk of falls or near-falls</li>
                    <li><i class="fa-solid fa-check-circle"></i> Changes in weight or nutrition</li>
                    <li><i class="fa-solid fa-check-circle"></i> Medication errors or missed doses</li>
                    <li><i class="fa-solid fa-check-circle"></i> Social withdrawal and loneliness</li>
                    <li><i class="fa-solid fa-check-circle"></i> Unwashed laundry or messy living areas</li>
                </ul>
            </div>
            <div style="background: var(--sand); padding: 50px; border-radius: 40px; text-align: center;">
                <h3 style="color: var(--brandPink); font-size: 1.8rem;">Local & Dedicated</h3>
                <p style="font-size: 1.1rem;">Based in Saint Helena Bay, we are your neighbors. We understand the unique needs of our coastal community.</p>
                <p><strong>15 Rooipypieslot Straat,<br>Saint Helena Bay, 7390</strong></p>
            </div>
        </div>
    </section>

    <section class="services-section" id="services" style="background: #fff;">
        <div class="container">
            <h2 style="text-align: center; font-size: 2.5rem;">Our Professional Services</h2>
            <div class="service-grid">
                {services.map((s) => (
                    <div class="pill"><i class={`fa-solid ${s.icon}`}></i> {s.name}</div>
                ))}
            </div>
        </div>
    </section>

    <section class="contact-cta" id="contact">
        <div class="container">
            <h2 style="font-size: 2.8rem;">Let's Create Your Care Plan</h2>
            <p style="font-size: 1.2rem;">Serving Saldanha Bay, St Helena Bay, Langebaan & surrounds.</p>
            <a href="tel:0621247451" class="eval-btn">CALL 062 124 7451</a>
        </div>
    </section>

    <footer style="background: var(--brandNavy); color: white; padding: 60px 0;">
        <div class="container" style="text-align: center;">
            <p><strong>WEST COAST HOMECARE SERVICES (Pty) Ltd</strong></p>
            <p style="opacity: 0.7; font-size: 0.9rem;">Giving you Peace of Mind | Reg: 2024/129640/07</p>
            <div style="margin-top: 25px; display: flex; justify-content: center; gap: 20px;">
                <a href="#" style="color: white; font-size: 1.2rem;"><i class="fa-brands fa-facebook"></i></a>
                <a href="#" style="color: white; font-size: 1.2rem;"><i class="fa-brands fa-instagram"></i></a>
            </div>
        </div>
    </footer>

</body>
</html>
