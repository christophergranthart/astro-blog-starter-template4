<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Coast Home Care | Backup Version</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Outfit:wght@800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --brand-pink: #E6007E;
            --brand-blue: #32B5E5;
            --brand-navy: #1A2B49;
            --retro-gold: #FFD700;
            --sand: #F4F1EA;
            --white: #ffffff;
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brand-navy);
            background-color: var(--white);
            line-height: 1.6;
        }

        /* PINK HEADER */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 8%;
            background-color: var(--brand-pink);
            border-bottom: 5px solid var(--brand-navy);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo-container { display: flex; align-items: center; gap: 12px; }
        .logo-small { height: 50px; width: auto; border-radius: 50%; border: 2px solid white; }
        .logo-text { font-weight: 700; font-size: 1.2rem; color: white; }
        
        nav a {
            text-decoration: none;
            color: white;
            margin-left: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        /* HERO SECTION */
        .hero {
            display: flex;
            align-items: center;
            padding: 60px 8%;
            background: linear-gradient(90deg, #fff 70%, var(--sand) 100%);
        }

        .hero-text { flex: 1; max-width: 500px; }
        .hero-text h1 { font-family: 'Outfit', sans-serif; font-size: 3.5rem; line-height: 1.1; margin-bottom: 20px; }
        .hero-text h1 span { color: var(--brand-pink); }

        .hero-art { flex: 1; display: flex; justify-content: center; }
        .hero-art img {
            width: 100%;
            max-width: 450px;
            border: 10px solid var(--brand-navy);
            box-shadow: 20px 20px 0 var(--retro-gold);
            border-radius: 20px; /* Merging your backup with the frame look */
        }

        .cta-btn {
            background-color: var(--brand-pink);
            color: white;
            border: 4px solid var(--brand-navy);
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 6px 6px 0 var(--brand-navy);
            transition: 0.3s;
        }

        .cta-btn:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--brand-blue); }

        /* TESTIMONIAL CAROUSEL */
        .testimonials {
            background: var(--brand-navy);
            color: white;
            padding: 60px 8%;
            text-align: center;
        }
        .slide { display: none; }
        .slide.active { display: block; animation: fadeIn 0.5s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* REASON CARDS (The "Stripe" Look) */
        .services { padding: 80px 8%; text-align: center; }
        .service-grid { display: flex; gap: 25px; margin-top: 50px; flex-wrap: wrap; }
        .card {
            background: white;
            padding: 40px;
            flex: 1 1 250px;
            border-left: 15px solid var(--brand-pink);
            border-bottom: 6px solid var(--brand-navy);
            box-shadow: 10px 10px 30px rgba(0,0,0,0.05);
            text-align: left;
        }

        /* SERVICE PILLS */
        .pill {
            display: inline-block;
            background: var(--sand);
            padding: 10px 20px;
            border-radius: 50px;
            margin: 5px;
            font-weight: 700;
            border: 2px solid var(--brand-navy);
        }

        @media (max-width: 768px) {
            .hero { flex-direction: column; text-align: center; }
            header { flex-direction: column; height: auto; padding: 20px; gap: 10px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-container">
            <img src="img/West CoastArtisticBanner.jpg" alt="Logo" class="logo-small">
            <div class="logo-text">West Coast Home Care</div>
        </div>
        <nav>
            <a href="#about">HOME</a>
            <a href="#services">SERVICES</a>
            <a href="tel:0621247451">CONTACT</a>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Trusted & <br><span>Personalised</span> <br>Home Care.</h1>
            <p>Compassionate care for the elderly and frail. We help your loved ones live with joy and independence.</p>
            <button class="cta-btn">CONTACT US</button>
        </div>
        <div class="hero-art">
            <img src="img/West CoastArtisticBanner.jpg" alt="Homecare Image">
        </div>
    </section>

    <section class="testimonials">
        <div class="slide active">
            <p style="font-size: 1.5rem; font-style: italic;">"Your kindness and genuine companionship mean more to us than you know."</p>
            <p style="color: var(--brand-blue); font-weight: 700;">— Family Member</p>
        </div>
        <div class="slide">
            <p style="font-size: 1.5rem; font-style: italic;">"Professional, punctual, and truly caring. Best service on the West Coast."</p>
            <p style="color: var(--brand-blue); font-weight: 700;">— Sarah M.</p>
        </div>
    </section>

    <section class="services" id="about">
        <h2>Reasons to call West Coast Care</h2>
        <div class="service-grid">
            <div class="card"><h3>Errands & Shopping</h3></div>
            <div class="card"><h3>Medical Appointments</h3></div>
            <div class="card"><h3>Companionship</h3></div>
        </div>
    </section>

    <section style="padding: 60px 8%; text-align:center;" id="services">
        <h2>Full Service List</h2>
        <div class="pill">24h Frail Care</div>
        <div class="pill">Dementia Care</div>
        <div class="pill">Meal Prep</div>
        <div class="pill">Housekeeping</div>
        <div class="pill">Medication Reminders</div>
    </section>

    <script>
        let current = 0;
        const slides = document.querySelectorAll('.slide');
        setInterval(() => {
            slides[current].classList.remove('active');
            current = (current + 1) % slides.length;
            slides[current].classList.add('active');
        }, 5000);
    </script>
</body>
</html>
