<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Coast Home Care | Full Service Support</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&family=Outfit:wght@800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --brand-pink: #E6007E;
            --brand-blue: #32B5E5;
            --brand-navy: #1A2B49;
            --retro-gold: #FFD700;
            --white: #ffffff;
            --bg-light: #F8FAFC;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            background-color: var(--bg-light);
            color: var(--brand-navy);
            scroll-behavior: smooth;
        }

        /* --- PINK STATIC HEADER --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 8%;
            background-color: var(--brand-pink);
            height: 90px;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 6px solid var(--brand-navy);
        }
        .logo-area { display: flex; align-items: center; gap: 15px; color: white; }
        .logo-img { height: 60px; border: 2px solid white; border-radius: 50%; }
        .logo-text { font-family: 'Outfit', sans-serif; font-size: 1.1rem; text-transform: uppercase; line-height: 1; }
        
        nav a { text-decoration: none; color: white; font-weight: 800; margin-left: 20px; font-size: 0.9rem; }

        /* --- HERO SECTION --- */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            padding: 80px 8%;
            align-items: center;
            gap: 50px;
        }
        .hero-text h1 { font-family: 'Outfit', sans-serif; font-size: 4rem; line-height: 1; margin-bottom: 25px; }
        .hero-text h1 span { color: var(--brand-pink); }

        .hero-art img { 
            width: 100%; 
            max-width: 500px; 
            border: 10px solid var(--brand-navy); 
            box-shadow: 20px 20px 0 var(--retro-gold);
        }

        /* --- TESTIMONIAL CAROUSEL --- */
        .testimonial-wrap {
            background: var(--brand-navy);
            padding: 80px 8%;
            color: white;
            text-align: center;
            border-top: 10px solid var(--brand-blue);
        }
        .slide { display: none; animation: fadeIn 0.5s ease; }
        .slide.active { display: block; }
        .testimonial-text { font-family: 'Outfit', sans-serif; font-size: 1.8rem; font-style: italic; max-width: 800px; margin: 0 auto; }
        
        .dots { display: flex; justify-content: center; gap: 10px; margin-top: 30px; }
        .dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.3); border: none; cursor: pointer; }
        .dot.active { background: var(--brand-pink); width: 30px; border-radius: 10px; }

        /* --- STRIPE CARDS --- */
        .reasons-section { padding: 100px 8%; }
        .reasons-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }
        .reason-card { 
            padding: 40px; 
            background: white; 
            border-left: 15px solid var(--brand-pink); 
            border-bottom: 8px solid var(--brand-navy);
            box-shadow: 10px 10px 30px rgba(0,0,0,0.05);
        }
        .reason-card i { font-size: 2.5rem; color: var(--brand-blue); margin-bottom: 20px; }

        /* --- SERVICE PILLS --- */
        .pill { 
            display: inline-block;
            background: #fff;
            padding: 12px 25px;
            margin: 8px;
            border: 3px solid var(--brand-navy);
            font-weight: 700;
            box-shadow: 5px 5px 0 var(--retro-gold);
        }

        /* --- NADINE SECTION --- */
        .profile-section {
            background: #f1f5f9;
            padding: 80px 8%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }
        .profile-img img {
            width: 100%;
            border: 8px solid var(--brand-navy);
            border-radius: 20px;
            box-shadow: -15px 15px 0 var(--brand-pink);
        }

        .cta-btn { 
            background: var(--brand-pink); 
            color: white; 
            padding: 20px 40px; 
            border: 4px solid var(--brand-navy); 
            font-weight: 800; 
            text-decoration: none; 
            display: inline-block;
            box-shadow: 8px 8px 0 var(--brand-navy);
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        @media (max-width: 900px) {
            .hero, .profile-section { grid-template-columns: 1fr; text-align: center; }
            header { padding: 0 5%; flex-direction: column; height: auto; padding: 15px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-area">
            <img src="img/West CoastArtisticBanner.jpg" alt="Logo" class="logo-img">
            <div class="logo-text">West Coast<br>Home Care</div>
        </div>
        <nav>
            <a href="#about">WHY US</a>
            <a href="#services">SERVICES</a>
            <a href="tel:0621247451">CALL NOW</a>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Trusted & <br><span>Personalised</span> <br>Home Care.</h1>
            <p>Compassionate care for the elderly, frail, and those in need of respite. We bring peace of mind to your family.</p>
            <a href="tel:0621247451" class="cta-btn">GET IN TOUCH</a>
        </div>
        <div class="hero-art">
            <img src="img/West CoastArtisticBanner.jpg" alt="Homecare">
        </div>
    </section>

    <section class="testimonial-wrap">
        <div id="slider">
            <div class="slide active">
                <p class="testimonial-text">"Your kindness and genuine companionship mean more to us than you know. We're truly grateful."</p>
                <p style="margin-top:20px; color:var(--brand-blue); font-weight:700;">— Family of Client</p>
            </div>
            <div class="slide">
                <p class="testimonial-text">"Professional, punctual, and truly caring. Best homecare service on the West Coast."</p>
                <p style="margin-top:20px; color:var(--brand-blue); font-weight:700;">— Sarah M., St Helena Bay</p>
            </div>
        </div>
        <div class="dots">
            <button class="dot active" onclick="setSlide(0)"></button>
            <button class="dot" onclick="setSlide(1)"></button>
        </div>
    </section>

    <section class="reasons-section" id="about">
        <h2 style="font-family:'Outfit'; font-size: 3rem; text-align:center; margin-bottom:60px;">Why Trust Us?</h2>
        <div class="reasons-grid">
            <div class="reason-card">
                <i class="fa-solid fa-heart"></i>
                <h3>Local Roots</h3>
                <p>Owned and operated in the heart of the West Coast community.</p>
            </div>
            <div class="reason-card">
                <i class="fa-solid fa-shield-check"></i>
                <h3>Vetted Care</h3>
                <p>Every caregiver is hand-picked, trained, and deeply compassionate.</p>
            </div>
            <div class="reason-card">
                <i class="fa-solid fa-calendar-check"></i>
                <h3>Tailored Plans</h3>
                <p>We build specialized care plans around your family's specific needs.</p>
            </div>
        </div>
    </section>

    <section class="profile-section">
        <div class="profile-img">
            <img src="img/West CoastArtisticBanner.jpg" alt="Nadine Saunders">
        </div>
        <div>
            <h2 style="font-family:'Outfit'; font-size: 2.5rem;">Meet Nadine Saunders</h2>
            <p>Registered Nursing Agency based in Saint Helena Bay. We provide professional support across Saldanha Bay and the surrounds.</p>
            <p><strong>REG: 2024/129640/07</strong></p>
            <a href="tel:0621247451" class="cta-btn">Call: 062 124 7451</a>
        </div>
    </section>

    <section style="padding: 100px 8%; text-align:center;" id="services">
        <h2 style="font-family:'Outfit'; font-size: 2.5rem; margin-bottom:40px;">Our Services</h2>
        <div class="pill">Day & Night Care</div>
        <div class="pill">Meal Preparation</div>
        <div class="pill">Light Housekeeping</div>
        <div class="pill">Medication Reminders</div>
        <div class="pill">Hygiene & Dressing</div>
        <div class="pill">Dementia Care</div>
        <div class="pill">24h Frail Care</div>
        <div class="pill">Companionship</div>
    </section>

    <footer style="background:var(--brand-navy); color:white; padding:40px 8%; text-align:center;">
        <p>&copy; 2026 West Coast Homecare Services (Pty) Ltd</p>
    </footer>

    <script>
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.dot');
        function setSlide(index) {
            slides.forEach(s => s.classList.remove('active'));
            dots.forEach(d => d.classList.remove('active'));
            slides[index].classList.add('active');
            dots[index].classList.add('active');
        }
        setInterval(() => {
            let current = Array.from(dots).findIndex(d => d.classList.contains('active'));
            setSlide((current + 1) % slides.length);
        }, 5000);
    </script>
</body>
</html>
