---
// West Coast Homecare Services - Premium Visual Edition
const pageTitle = "West Coast Homecare Services | Peace of Mind";
const brandPink = "#E6007E";
const brandBlue = "#32B5E5";
const brandNavy = "#1A2B49";
const sand = "#FDFBFA"; // Lightened sand for a cleaner look

const services = [
  "Day & Night Care",
  "Meal Preparation",
  "Light Housekeeping",
  "Medication Reminders",
  "Hygiene & Dressing",
  "Dementia Care",
  "24h Frail Care",
  "Companionship & Connection"
];

const reasons = [
  "Locally owned, community rooted service",
  "Compassionate, trained & vetted caregivers",
  "Flexible, personalised care plans",
  "Support across Saldanha Bay & surrounding areas"
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style define:vars={{ brandPink, brandBlue, brandNavy, sand }}>
        :root {
            --white: #ffffff;
            --gold: #FFD700;
            --soft-shadow: 0 10px 30px -5px rgba(26, 43, 73, 0.1);
            --deep-shadow: 0 20px 40px -10px rgba(26, 43, 73, 0.2);
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brandNavy);
            background-color: #fcfcfc;
            line-height: 1.7;
            scroll-behavior: smooth;
        }

        h1, h2, h3 {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
        }

        /* --- NAVIGATION --- */
        header {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1.2fr;
            align-items: center;
            padding: 0 5%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(230, 0, 126, 0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 95px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }

        .header-left { display: flex; align-items: center; gap: 12px; }
        .logo-small { height: 65px; width: auto; border-radius: 50%; box-shadow: 0 4px 10px rgba(0,0,0,0.1); transition: transform 0.3s; }
        .logo-small:hover { transform: scale(1.05); }
        .logo-text { font-weight: 700; font-size: 0.9rem; line-height: 1.1; margin: 0; text-transform: uppercase; color: var(--brandNavy); }

        nav { display: flex; justify-content: center; gap: 30px; }
        nav a {
            text-decoration: none;
            color: var(--brandNavy);
            font-size: 0.95rem;
            font-weight: 700;
            transition: 0.3s;
        }
        nav a:hover { color: var(--brandPink); }

        .header-right { display: flex; justify-content: flex-end; gap: 20px; }
        .header-right a { 
            color: var(--brandNavy); 
            font-size: 1.4rem; 
            transition: 0.3s; 
            background: #f8f8f8;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }
        .header-right a:hover { background: var(--brandPink); color: white; transform: translateY(-3px); }

        /* --- HERO SECTION --- */
        .hero {
            display: flex;
            align-items: center;
            padding: 100px 8%;
            background: radial-gradient(circle at top right, rgba(50, 181, 229, 0.05), transparent),
                        radial-gradient(circle at bottom left, rgba(230, 0, 126, 0.05), transparent);
            position: relative;
            overflow: hidden;
        }
        .hero-text { flex: 1; z-index: 2; }
        .hero-text h1 { font-size: 4rem; line-height: 1.05; margin-bottom: 25px; color: var(--brandNavy); }
        .hero-text h1 span { color: var(--brandPink); font-style: italic; }
        .hero-text p { font-size: 1.25rem; margin-bottom: 40px; color: #555; max-width: 500px; }

        .hero-art { flex: 1; display: flex; justify-content: center; position: relative; }
        .hero-art img { 
            width: 90%; 
            max-width: 480px; 
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; 
            box-shadow: var(--deep-shadow);
            border: 8px solid white;
            animation: morph 8s ease-in-out infinite;
        }

        @keyframes morph {
            0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
            50% { border-radius: 50% 50% 33% 67% / 55% 27% 73% 45%; }
            100% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
        }

        /* --- TESTIMONIAL --- */
        .testimonial-bar {
            background: linear-gradient(to right, var(--brandNavy), #2a3e61);
            color: white;
            padding: 100px 10%;
            text-align: center;
            position: relative;
        }
        .testimonial-text { font-size: 1.6rem; font-family: 'Playfair Display', serif; line-height: 1.6; font-style: italic; z-index: 1; position: relative; }
        .testimonial-author { margin-top: 20px; color: var(--brandBlue); font-weight: 700; text-transform: uppercase; letter-spacing: 2px; }

        /* --- CARDS --- */
        .why-us { padding: 100px 8%; background: white; }
        .why-us h2 { text-align: center; font-size: 2.8rem; margin-bottom: 50px; }
        .reasons-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 30px; }
        .reason-card { 
            padding: 40px; 
            background: white; 
            border-radius: 24px; 
            box-shadow: var(--soft-shadow);
            border: 1px solid rgba(0,0,0,0.03);
            transition: 0.4s;
        }
        .reason-card:hover { transform: translateY(-10px); box-shadow: var(--deep-shadow); border-color: var(--brandBlue); }
        .reason-card i { font-size: 3rem; color: var(--brandPink); margin-bottom: 25px; display: block; }

        /* --- SIGNS BOX --- */
        .signs-section { padding: 100px 8%; background: #f9f9f9; }
        .signs-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 400px; gap: 60px; align-items: center; }
        .signs-list li { background: white; padding: 15px 20px; border-radius: 12px; margin-bottom: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); display: flex; align-items: center; gap: 15px; font-weight: 700; }
        .signs-list i { color: var(--brandPink); }

        .nadine-box { 
            background: white; 
            padding: 50px; 
            border-radius: 30px; 
            box-shadow: var(--deep-shadow); 
            border-top: 5px solid var(--brandPink);
            text-align: center;
        }

        /* --- PILLS --- */
        .service-grid { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; padding-top: 50px; }
        .pill { 
            background: white; 
            padding: 18px 35px; 
            border-radius: 50px; 
            font-weight: 700; 
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border: 2px solid transparent; 
            transition: 0.3s;
        }
        .pill:hover { border-color: var(--brandPink); transform: scale(1.05); color: var(--brandPink); }

        /* --- FOOTER --- */
        .contact-cta { 
            background: linear-gradient(rgba(26, 43, 73, 0.9), rgba(26, 43, 73, 0.9)), url('https://www.transparenttextures.com/patterns/cubes.png');
            color: white; padding: 120px 8%; text-align: center; 
        }
        .eval-btn { 
            background: var(--brandPink); color: white; padding: 25px 60px; border-radius: 100px; 
            text-decoration: none; font-weight: 700; font-size: 1.2rem; display: inline-block; 
            box-shadow: 0 10px 25px rgba(230, 0, 126, 0.3); transition: 0.3s;
        }
        .eval-btn:hover { transform: scale(1.05); background: #ff1a96; }

        footer { background: #0d1625; color: rgba(255,255,255,0.6); padding: 80px 8%; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }

        @media (max-width: 950px) {
            .hero { flex-direction: column; text-align: center; padding-top: 60px; }
            .hero-text h1 { font-size: 2.8rem; }
            .signs-grid { grid-template-columns: 1fr; }
            header { grid-template-columns: 1fr 1fr; }
            nav { display: none; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-left">
            <img src="/logo.jpg" alt="Logo" class="logo-small">
            <div class="logo-details">
                <p class="logo-text">WEST COAST<br>HOMECARE</p>
            </div>
        </div>

        <nav>
            <a href="#">Home</a>
            <a href="#about">Why Us</a>
            <a href="#services">Services</a>
            <a href="#contact">Contact</a>
        </nav>

        <div class="header-right">
            <a href="tel:0621247451"><i class="fa-solid fa-phone"></i></a>
            <a href="https://wa.me/27621247451" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Expert Care,<br><span>Peace of Mind.</span></h1>
            <p>Dignified, professional homecare supporting families across the West Coast with heart and excellence.</p>
            <a href="tel:0621247451" class="eval-btn">Free Consultation</a>
        </div>
        <div class="hero-art">
            <img src="/West CoastArtisticBanner.jpg" alt="Homecare">
        </div>
    </section>

    <section class="testimonial-bar">
        <div class="testimonial-container">
            <div class="stars">
                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
            </div>
            <p class="testimonial-text">
                "Thank you for taking such wonderful care of my father. Your thoroughness, kindness, and genuine companionship mean more to us than you know."
            </p>
            <span class="testimonial-author">— Family of Client</span>
        </div>
    </section>

    <section class="why-us" id="about">
        <h2>Why Families Trust Us</h2>
        <div class="reasons-grid">
            {reasons.map((reason) => (
                <div class="reason-card">
                    <i class="fa-solid fa-shield-heart"></i>
                    <p><strong>{reason}</strong></p>
                </div>
            ))}
        </div>
    </section>

    <section class="signs-section">
        <div class="signs-grid">
            <div>
                <h2 style="font-size: 2.5rem;">Is it time for care?</h2>
                <ul class="signs-list" style="padding:0; list-style:none;">
                    <li><i class="fa-solid fa-circle-check"></i> Struggles with daily hygiene</li>
                    <li><i class="fa-solid fa-circle-check"></i> Difficulty moving safely at home</li>
                    <li><i class="fa-solid fa-circle-check"></i> Frequent falls or instability</li>
                    <li><i class="fa-solid fa-circle-check"></i> Changes in weight or nutrition</li>
                    <li><i class="fa-solid fa-circle-check"></i> Missed medications or confusion</li>
                    <li><i class="fa-solid fa-circle-check"></i> Social isolation and loneliness</li>
                </ul>
            </div>
            <div class="nadine-box">
                <h3 style="color: var(--brandPink);">"Family comes first."</h3>
                <p><strong>Nadine Saunders</strong></p>
                <p style="font-size: 0.9rem; opacity: 0.7;">Registered Nursing Agency<br>Saint Helena Bay</p>
            </div>
        </div>
    </section>

    <section class="services" id="services" style="padding: 100px 8%; background:white; text-align:center;">
        <h2>Professional Support Services</h2>
        <div class="service-grid">
            {services.map((service) => (
                <div class="pill">{service}</div>
            ))}
        </div>
    </section>

    <section class="contact-cta" id="contact">
        <h2>Ready to talk about your family's needs?</h2>
        <p style="margin-bottom: 40px; opacity: 0.9;">Available across Saldanha Bay, St Helena Bay & the West Coast.</p>
        <a href="tel:0621247451" class="eval-btn">Call 062 124 7451</a>
    </section>

    <footer>
        <p style="color: white; font-weight: 700;">WEST COAST HOMECARE SERVICES (Pty) Ltd</p>
        <p>15 Rooipypieslot Straat, Saint Helena Bay<br>REG: 2024/129640/07</p>
    </footer>

</body>
</html>
