<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Coast Home Care | Compassionate & Professional</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* BRAND COLORS */
        :root {
            --brand-pink: #E6007E;
            --brand-blue: #32B5E5;
            --brand-navy: #1A2B49;
            --sand: #F4F1EA;
            --white: #ffffff;
            --light-gray: #f9f9f9;
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brand-navy);
            background-color: var(--white);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* HEADER & LOGO */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 8%;
            border-bottom: 1px solid #eee;
            background: var(--white);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-small {
            height: 50px; /* Scaled for website navigation */
            width: auto;
            border-radius: 50%;
        }

        .logo-text { 
            font-weight: 700; 
            font-size: 1.1rem; 
            color: var(--brand-navy);
        }
        
        .logo-text span.blue-text { color: var(--brand-blue); }
        .logo-text span.pink-text { color: var(--brand-pink); }

        nav a {
            text-decoration: none;
            color: var(--brand-navy);
            margin-left: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--brand-blue);
        }

        /* HERO SECTION */
        .hero {
            display: flex;
            align-items: center;
            padding: 80px 8%;
            background: linear-gradient(135deg, #fff 60%, var(--sand) 100%);
            min-height: 60vh;
        }

        .hero-text { flex: 1; max-width: 550px; }
        .hero-text h1 { font-size: 3.2rem; line-height: 1.1; margin-bottom: 20px; color: var(--brand-navy); }
        .hero-text h1 span { color: var(--brand-blue); }
        .hero-text p { font-size: 1.1rem; margin-bottom: 30px; color: #555; }

        .hero-art {
            flex: 1;
            display: flex;
            justify-content: center;
            position: relative;
        }

        .hero-art img {
            width: 90%;
            max-width: 450px;
            filter: drop-shadow(0px 20px 40px rgba(0,0,0,0.1));
            border-radius: 50%; /* Keeps the logo shape consistent */
        }

        /* BUTTONS */
        .cta-btn {
            background-color: var(--brand-pink);
            color: white;
            border: none;
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(230, 0, 126, 0.3);
        }

        .cta-btn:hover { 
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(230, 0, 126, 0.4);
        }

        /* SERVICES SECTION - MEDICAL PILL SHAPES */
        .services {
            padding: 80px 8%;
            text-align: center;
            background-color: var(--light-gray);
        }

        .services h2 {
            font-size: 2.2rem;
            color: var(--brand-navy);
            margin-bottom: 50px;
        }

        .service-grid {
            display: flex;
            gap: 25px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .card {
            background: var(--white);
            color: var(--brand-navy);
            padding: 40px 25px;
            flex: 1 1 260px;
            max-width: 300px;
            min-height: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            
            /* Medical Pill/Leaf Shape */
            border-radius: 50px 5px 50px 5px;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        }

        /* Professional Accent Strip */
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 8px;
            height: 100%;
            background-color: var(--brand-blue);
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-8px);
            border-color: var(--brand-pink);
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        }

        .card:hover::before {
            background-color: var(--brand-pink);
        }

        /* Alternating shape for rhythm */
        .card:nth-child(2) {
            border-radius: 5px 50px 5px 50px;
        }
        .card:nth-child(2)::before {
            left: auto;
            right: 0;
        }

        .card h3 {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 700;
            line-height: 1.4;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .hero { flex-direction: column; text-align: center; padding-top: 40px; }
            .hero-text { margin-bottom: 50px; }
            header { flex-direction: column; gap: 15px; }
            nav a { margin: 0 10px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-container">
            <img src="img/West CoastArtisticBanner.jpg" alt="West Coast Logo" class="logo-small">
            <div class="logo-text">
                West Coast <span class="blue-text">Home Care</span> <span class="pink-text">Services</span>
            </div>
        </div>
        <nav>
            <a href="#">HOME</a>
            <a href="#">SERVICES</a>
            <a href="#">CONTACT</a>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Trusted & <br><span>Personalised</span> <br>Home Care.</h1>
            <p>Providing compassionate support for the elderly and frail, ensuring independence and joy in the heart of the West Coast.</p>
            <button class="cta-btn">CONTACT US TODAY</button>
        </div>
        <div class="hero-art">
            <img src="img/West CoastArtisticBanner.jpg" alt="West Coast Care Banner">
        </div>
    </section>

    <section class="services">
        <h2>Specialist Care Support</h2>
        <div class="service-grid">
            <div class="card">
                <h3>Helping run <br> errands</h3>
            </div>
            <div class="card">
                <h3>Keeping <br> appointments</h3>
            </div>
            <div class="card">
                <h3>Meaningful <br> Companionship</h3>
            </div>
        </div>
    </section>

</body>
</html>
