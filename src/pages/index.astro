---
// West Coast Homecare Services - Fresh High-Contrast Edition
const pageTitle = "West Coast Homecare Services | Peace of Mind";
const brandPink = "#E6007E";
const brandBlue = "#32B5E5";
const brandNavy = "#1A2B49";
const freshWhite = "#F8FAFC"; // Replaces the "brownish" sand

const services = [
  "Day & Night Care",
  "Meal Preparation",
  "Light Housekeeping",
  "Medication Reminders",
  "Hygiene & Dressing",
  "Dementia Care",
  "24h Frail Care",
  "Companionship & Connection"
];

const reasons = [
  "Locally owned, community rooted",
  "Compassionate & vetted caregivers",
  "Flexible, personalised care plans",
  "Support across Saldanha Bay areas"
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style define:vars={{ brandPink, brandBlue, brandNavy, freshWhite }}>
        :root {
            --white: #ffffff;
            --accent-glow: rgba(230, 0, 126, 0.1);
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brandNavy);
            background-color: var(--freshWhite); /* CLEAN NEW BACKGROUND */
            line-height: 1.6;
            scroll-behavior: smooth;
        }

        h1, h2 { font-family: 'Playfair Display', serif; }

        /* --- MODERN HEADER --- */
        header {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1.2fr;
            align-items: center;
            padding: 0 5%;
            background: var(--white);
            border-bottom: 3px solid var(--brandBlue); /* Bold blue line */
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 95px;
        }

        .logo-text { font-weight: 700; font-size: 0.9rem; text-transform: uppercase; color: var(--brandNavy); }
        .logo-small { height: 65px; border-radius: 50%; }

        nav a {
            text-decoration: none;
            color: var(--brandNavy);
            font-weight: 700;
            margin: 0 15px;
            transition: 0.3s;
        }
        nav a:hover { color: var(--brandPink); }

        .header-right a {
            color: var(--white);
            background: var(--brandNavy);
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            margin-left: 10px;
            transition: 0.3s;
        }
        .header-right a:hover { background: var(--brandPink); transform: scale(1.1); }

        /* --- BOLD HERO --- */
        .hero {
            display: flex;
            align-items: center;
            padding: 80px 8%;
            background: linear-gradient(135deg, #ffffff 50%, #e0f2fe 100%); /* Blue tint gradient */
        }
        .hero-text h1 { font-size: 3.5rem; margin-bottom: 20px; line-height: 1.1; }
        .hero-text h1 span { color: var(--brandPink); }
        .hero-text p { font-size: 1.2rem; color: #444; margin-bottom: 30px; }

        .hero-art img { 
            width: 100%; 
            max-width: 450px; 
            border: 10px solid white; 
            box-shadow: 0 30px 60px -12px rgba(50,50,93,0.25);
            border-radius: 20px;
        }

        /* --- POPPING TESTIMONIAL --- */
        .testimonial-bar {
            background: var(--brandNavy);
            color: white;
            padding: 80px 10%;
            text-align: center;
            border-top: 5px solid var(--brandPink);
        }
        .testimonial-text { font-size: 1.5rem; font-style: italic; font-family: 'Playfair Display', serif; }

        /* --- FLOATING CARDS --- */
        .why-us { padding: 80px 8%; text-align: center; }
        .reasons-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; }
        .reason-card { 
            padding: 40px; 
            background: var(--white); 
            border-radius: 15px; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.05); 
            border-bottom: 5px solid var(--brandBlue);
            transition: 0.3s;
        }
        .reason-card:hover { transform: translateY(-10px); box-shadow: 0 30px 60px rgba(0,0,0,0.1); }
        .reason-card i { font-size: 2.5rem; color: var(--brandPink); margin-bottom: 20px; }

        /* --- SIGNS SECTION (DARK CONTRAST) --- */
        .signs-section { padding: 80px 8%; background: #f1f5f9; }
        .signs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; max-width: 1100px; margin: 0 auto; }
        .signs-list li { background: white; margin: 10px 0; padding: 15px; border-radius: 10px; list-style: none; font-weight: 700; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); }
        .signs-list i { color: var(--brandPink); }

        .nadine-box { background: var(--brandNavy); color: white; padding: 40px; border-radius: 20px; text-align: center; }

        /* --- SERVICE PILLS --- */
        .service-grid { display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; padding: 50px 0; }
        .pill { 
            background: var(--white); 
            padding: 15px 30px; 
            border-radius: 50px; 
            font-weight: 700; 
            border: 2px solid var(--brandBlue);
            box-shadow: 4px 4px 0 var(--brandBlue);
            transition: 0.2s;
        }
        .pill:hover { transform: translate(-2px, -2px); box-shadow: 7px 7px 0 var(--brandPink); border-color: var(--brandPink); }

        /* --- CTA --- */
        .contact-cta { background: var(--brandBlue); color: white; padding: 100px 8%; text-align: center; }
        .eval-btn { 
            background: var(--brandPink); color: white; padding: 20px 50px; border-radius: 50px; 
            text-decoration: none; font-weight: 700; font-size: 1.2rem; display: inline-block; 
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .eval-btn:hover { background: var(--brandNavy); transform: scale(1.05); }

        footer { background: #0f172a; color: #94a3b8; padding: 60px 8%; text-align: center; }

        @media (max-width: 900px) {
            .hero, .signs-grid { flex-direction: column; grid-template-columns: 1fr; text-align: center; }
            header { grid-template-columns: 1fr 1fr; }
            nav { display: none; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-left">
            <img src="/logo.jpg" alt="Logo" class="logo-small">
            <div class="logo-details">
                <p class="logo-text">WEST COAST<br>HOMECARE</p>
            </div>
        </div>
        <nav>
            <a href="#">Home</a>
            <a href="#about">Why Us</a>
            <a href="#services">Services</a>
        </nav>
        <div class="header-right">
            <a href="tel:0621247451"><i class="fa-solid fa-phone"></i></a>
            <a href="https://wa.me/27621247451" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Giving you <br><span>Peace of Mind.</span></h1>
            <p>Professional, compassionate home care across Saldanha Bay and the West Coast. Because family comes first.</p>
            <a href="tel:0621247451" class="eval-btn">Free Consultation</a>
        </div>
        <div class="hero-art">
            <img src="/West CoastArtisticBanner.jpg" alt="Homecare Image">
        </div>
    </section>

    <section class="testimonial-bar">
        <p class="testimonial-text">"Your kindness and genuine companionship mean more to us than you know. We're truly grateful for your amazing heart."</p>
        <p style="color: var(--brandBlue); font-weight: 700; margin-top: 15px;">— Family of Client</p>
    </section>

    <section class="why-us" id="about">
        <h2>Why Families Trust Us</h2>
        <div class="reasons-grid">
            {reasons.map((reason) => (
                <div class="reason-card">
                    <i class="fa-solid fa-heart-pulse"></i>
                    <p><strong>{reason}</strong></p>
                </div>
            ))}
        </div>
    </section>

    <section class="signs-section">
        <div class="signs-grid">
            <div>
                <h2>Signs care may be needed</h2>
                <ul class="signs-list" style="padding:0;">
                    <li><i class="fa-solid fa-check"></i> Struggles with daily hygiene</li>
                    <li><i class="fa-solid fa-check"></i> Difficulty moving safely</li>
                    <li><i class="fa-solid fa-check"></i> Changes in weight or nutrition</li>
                    <li><i class="fa-solid fa-check"></i> Medication errors or confusion</li>
                    <li><i class="fa-solid fa-check"></i> Isolation and loneliness</li>
                </ul>
            </div>
            <div class="nadine-box">
                <h3 style="color: var(--brandBlue);">Nadine Saunders</h3>
                <p>Registered Nursing Agency</p>
                <p>Saint Helena Bay, South Africa</p>
                <a href="tel:0621247451" style="color:var(--brandPink); font-weight:700; text-decoration:none;">062 124 7451</a>
            </div>
        </div>
    </section>

    <section style="padding: 80px 8%; text-align: center; background: white;">
        <h2>Our Professional Services</h2>
        <div class="service-grid">
            {services.map((service) => (
                <div class="pill">{service}</div>
            ))}
        </div>
    </section>

    <section class="contact-cta" id="contact">
        <h2>Let's create a care plan together.</h2>
        <a href="tel:0621247451" class="eval-btn">Call Now</a>
    </section>

    <footer>
        <p>&copy; 2026 West Coast Homecare Services (Pty) Ltd</p>
        <p>REG: 2024/129640/07</p>
    </footer>

</body>
</html>
