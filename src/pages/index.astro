<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Coast Home Care | Professional Support</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-pink: #E6007E;
            --brand-blue: #32B5E5;
            --brand-navy: #1A2B49;
            --sand: #F4F1EA;
            --white: #ffffff;
        }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--brand-navy);
            background-color: var(--white);
            line-height: 1.6;
        }

        /* HEADER & NAVIGATION */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 8%;
            border-bottom: 1px solid #eee;
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-small {
            height: 55px;
            width: auto;
        }

        .logo-text { 
            font-weight: 700; 
            font-size: 1.1rem; 
        }
        
        .logo-text span.blue-text { color: var(--brand-blue); }
        .logo-text span.pink-text { color: var(--brand-pink); }

        nav a {
            text-decoration: none;
            color: var(--brand-navy);
            margin-left: 20px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        /* HERO SECTION */
        .hero {
            display: flex;
            align-items: center;
            padding: 60px 8%;
            background: linear-gradient(90deg, #fff 70%, var(--sand) 100%);
        }

        .hero-text { flex: 1; max-width: 500px; }
        .hero-text h1 { font-size: 3rem; line-height: 1.1; margin-bottom: 20px; }
        .hero-text h1 span { color: var(--brand-blue); }
        .hero-text p { font-size: 1.1rem; margin-bottom: 30px; }

        .hero-art {
            flex: 1;
            display: flex;
            justify-content: center;
        }

        .hero-art img {
            width: 80%;
            max-width: 400px;
            filter: drop-shadow(0px 15px 30px rgba(0,0,0,0.1));
            border-radius: 50%;
        }

        .cta-btn {
            background-color: var(--brand-pink);
            color: white;
            border: none;
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .cta-btn:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(230, 0, 126, 0.3); }

        /* SERVICES SECTION - CORRECTED PILL SHAPES */
        .services {
            padding: 80px 8%;
            text-align: center;
        }

        .services h2 {
            margin-bottom: 50px;
            font-size: 2rem;
        }

        .service-grid {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        /* This is the true Capsule/Pill shape */
        .card {
            background: var(--sand);
            padding: 25px 45px;
            flex: 1 1 250px;
            max-width: 320px;
            min-height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            
            /* HIGH BORDER RADIUS creates the pill look */
            border-radius: 100px; 
            border: 2px solid transparent;
        }

        .card:hover {
            background-color: var(--white);
            border-color: var(--brand-blue);
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

        /* Alternating color style for a funky/medical mix */
        .card:nth-child(2) {
            border-radius: 100px;
            border: 2px solid var(--brand-blue);
            background-color: var(--white);
        }

        .card:nth-child(2):hover {
            border-color: var(--brand-pink);
        }

        .card h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .hero { flex-direction: column; text-align: center; }
            header { flex-direction: column; gap: 15px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-container">
            <img src="img/West CoastArtisticBanner.jpg" alt="Logo" class="logo-small">
            <div class="logo-text">
                West Coast <span class="blue-text">Home Care</span> <span class="pink-text">Services</span>
            </div>
        </div>
        <nav>
            <a href="#">HOME</a>
            <a href="#">SERVICES</a>
            <a href="#">CONTACT</a>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Trusted & <br><span>Personalised</span> <br>Home Care.</h1>
            <p>Compassionate care for the elderly, frail, and those in need of respite. We bring peace of mind to your family.</p>
            <button class="cta-btn">GET IN TOUCH</button>
        </div>
        <div class="hero-art">
            <img src="img/West CoastArtisticBanner.jpg" alt="West Coast Care">
        </div>
    </section>

    <section class="services">
        <h2>Our Core Support</h2>
        <div class="service-grid">
            <div class="card">
                <h3>Errands & <br> Shopping</h3>
            </div>
            <div class="card">
                <h3>Medical <br> Appointments</h3>
            </div>
            <div class="card">
                <h3>Respite & <br> Companionship</h3>
            </div>
        </div>
    </section>

</body>
</html>
