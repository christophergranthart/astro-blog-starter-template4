---
// West Coast Homecare Services - Funky & Dynamic Edition
const pageTitle = "West Coast Homecare Services | Peace of Mind";
const retroPink = "#E6007E";
const retroBlue = "#32B5E5";
const deepCharcoal = "#1A2B49";
const retroGold = "#FFD700";
const softSand = "#FDFBFA"; 

const services = [
  "Day & Night Care",
  "Meal Preparation",
  "Light Housekeeping",
  "Medication Reminders",
  "Hygiene & Dressing",
  "Dementia Care",
  "24h Frail Care",
  "Companionship"
];

const reasons = [
  { title: "Local Roots", desc: "Owned and operated in the heart of the West Coast community." },
  { title: "Vetted Care", desc: "Every caregiver is hand-picked, trained, and deeply compassionate." },
  { title: "Tailored Plans", desc: "No two families are the same. We build care around your life." },
  { title: "Full Support", desc: "Active across Saldanha Bay, St Helena Bay, and surrounds." }
];

const testimonials = [
    { text: "Thank you for taking such wonderful care of my father. Your thoroughness and kindness mean more to us than you know.", author: "Ldw | Family Member" },
    { text: "The peace of mind Nadine and her team provide is priceless. They treat my mother like their own family.", author: "Sarah M. | St Helena Bay" },
    { text: "Professional, punctual, and truly caring. Best homecare service on the West Coast, hands down.", author: "Johan P. | Saldanha" }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Playfair+Display:wght@900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style define:vars={{ retroPink, retroBlue, deepCharcoal, retroGold, softSand }}>
        :root { --white: #ffffff; }

        body {
            font-family: 'Comfortaa', cursive;
            margin: 0;
            color: var(--deepCharcoal);
            background-color: var(--softSand);
            background-image: radial-gradient(var(--deepCharcoal) 0.5px, transparent 0.5px);
            background-size: 30px 30px; /* Subtle dot grid for texture */
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* --- FUNKY HEADER --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 5%;
            background: var(--white);
            border-bottom: 6px solid var(--deepCharcoal);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo-text { font-weight: 900; font-size: 1.1rem; line-height: 1; text-transform: uppercase; }

        /* --- HERO --- */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            padding: 80px 8%;
            align-items: center;
            gap: 40px;
        }
        .hero-text h1 { font-family: 'Playfair Display', serif; font-size: 4.5rem; line-height: 0.9; margin-bottom: 20px; }
        .hero-text h1 span { color: var(--retroPink); -webkit-text-stroke: 2px var(--deepCharcoal); }

        .hero-art img { 
            width: 100%; 
            border: 8px solid var(--deepCharcoal); 
            box-shadow: 20px 20px 0 var(--retroGold);
            transform: rotate(-2deg);
        }

        /* --- CAROUSEL TESTIMONIAL --- */
        .testimonial-section {
            background: var(--retroBlue);
            border-top: 6px solid var(--deepCharcoal);
            border-bottom: 6px solid var(--deepCharcoal);
            padding: 80px 5%;
            text-align: center;
            position: relative;
        }
        .carousel-container { max-width: 800px; margin: 0 auto; overflow: hidden; position: relative; }
        .testimonial-slide { display: none; padding: 20px; animation: fadeIn 0.5s; }
        .testimonial-slide.active { display: block; }
        .testimonial-text { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 900; color: var(--deepCharcoal); }
        
        .carousel-btns { margin-top: 30px; display: flex; justify-content: center; gap: 20px; }
        .c-btn { background: var(--white); border: 3px solid var(--deepCharcoal); width: 50px; height: 50px; cursor: pointer; font-size: 1.2rem; box-shadow: 4px 4px 0 var(--deepCharcoal); }
        .c-btn:active { transform: translate(2px, 2px); box-shadow: none; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* --- REASON CARDS (Modern Art Look) --- */
        .why-us { padding: 100px 8%; }
        .reasons-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 40px; }
        .reason-card { 
            padding: 40px; 
            background: var(--white); 
            border: 4px solid var(--deepCharcoal);
            box-shadow: 12px 12px 0 var(--retroPink);
            transition: 0.2s;
            position: relative;
        }
        .reason-card:hover { transform: translate(-5px, -5px); box-shadow: 17px 17px 0 var(--retroBlue); }
        .reason-card i { font-size: 3rem; color: var(--retroGold); -webkit-text-stroke: 2px var(--deepCharcoal); margin-bottom: 20px; }
        .reason-card h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; margin: 10px 0; }

        /* --- PILLS --- */
        .pill { 
            background: var(--retroGold); 
            padding: 15px 30px; 
            border: 3px solid var(--deepCharcoal); 
            font-weight: 700; 
            box-shadow: 6px 6px 0 var(--deepCharcoal);
            margin: 10px;
            display: inline-block;
        }

        /* --- CTA BUTTON --- */
        .eval-btn { 
            background: var(--retroPink); 
            color: white; 
            padding: 25px 50px; 
            border: 4px solid var(--deepCharcoal); 
            font-weight: 900; 
            font-size: 1.3rem; 
            text-decoration: none; 
            box-shadow: 10px 10px 0 var(--deepCharcoal);
            transition: 0.2s;
            display: inline-block;
        }
        .eval-btn:hover { transform: translate(-4px, -4px); box-shadow: 14px 14px 0 var(--deepCharcoal); }

        footer { background: var(--deepCharcoal); color: white; padding: 60px 8%; text-align: center; }

        @media (max-width: 900px) {
            .hero { grid-template-columns: 1fr; text-align: center; }
            .hero-text h1 { font-size: 3rem; }
        }
    </style>
</head>
<body>

    <header>
        <div style="display:flex; align-items:center; gap:15px;">
            <img src="/logo.jpg" alt="Logo" style="height:60px; border:3px solid var(--deepCharcoal);">
            <div class="logo-text">West Coast<br><span style="color:var(--retroPink)">Homecare</span></div>
        </div>
        <div class="header-right">
            <a href="tel:0621247451" class="eval-btn" style="padding: 10px 20px; font-size: 0.9rem; box-shadow: 4px 4px 0 var(--deepCharcoal);">CALL NOW</a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-text">
            <h1>Expert Care,<br><span>Peace of Mind.</span></h1>
            <p style="font-size: 1.3rem; font-weight: 700;">Taking Home Care to the Next Level across the West Coast.</p>
            <a href="tel:0621247451" class="eval-btn">FREE EVALUATION</a>
        </div>
        <div class="hero-art">
            <img src="/West CoastArtisticBanner.jpg" alt="Homecare Image">
        </div>
    </section>

    <section class="testimonial-section">
        <div class="carousel-container">
            {testimonials.map((t, index) => (
                <div class={`testimonial-slide ${index === 0 ? 'active' : ''}`}>
                    <div style="color:var(--white); font-size: 2rem; margin-bottom: 10px;">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                    </div>
                    <p class="testimonial-text">"{t.text}"</p>
                    <p style="font-weight:700; text-transform:uppercase; margin-top:20px;">— {t.author}</p>
                </div>
            ))}
        </div>
        <div class="carousel-btns">
            <button class="c-btn" id="prevBtn"><i class="fa-solid fa-arrow-left"></i></button>
            <button class="c-btn" id="nextBtn"><i class="fa-solid fa-arrow-right"></i></button>
        </div>
    </section>

    <section class="why-us">
        <h2 style="font-family:'Playfair Display'; font-size: 3.5rem; text-align:center; margin-bottom: 60px;">Why Trust Us?</h2>
        <div class="reasons-grid">
            {reasons.map((r) => (
                <div class="reason-card">
                    <i class="fa-solid fa-certificate"></i>
                    <h3>{r.title}</h3>
                    <p>{r.desc}</p>
                </div>
            ))}
        </div>
    </section>

    <section style="background:var(--deepCharcoal); padding: 80px 8%; text-align:center;">
        <h2 style="color:white; font-family:'Playfair Display'; font-size: 3rem; margin-bottom:40px;">Our Services</h2>
        {services.map((s) => (
            <div class="pill">{s}</div>
        ))}
    </section>

    <section style="padding: 100px 8%; text-align:center;">
        <h2 style="font-family:'Playfair Display'; font-size: 3rem;">Ready for better care?</h2>
        <p style="margin-bottom:40px;">Support across Saldanha Bay, St Helena Bay & the West Coast.</p>
        <a href="tel:0621247451" class="eval-btn">CONTACT NADINE TODAY</a>
    </section>

    <footer>
        <p style="font-weight:700;">WEST COAST HOMECARE SERVICES (Pty) Ltd</p>
        <p>15 Rooipypieslot Straat, Saint Helena Bay | REG: 2024/129640/07</p>
    </footer>

    <script>
        const slides = document.querySelectorAll('.testimonial-slide');
        let current = 0;

        document.getElementById('nextBtn').addEventListener('click', () => {
            slides[current].classList.remove('active');
            current = (current + 1) % slides.length;
            slides[current].classList.add('active');
        });

        document.getElementById('prevBtn').addEventListener('click', () => {
            slides[current].classList.remove('active');
            current = (current - 1 + slides.length) % slides.length;
            slides[current].classList.add('active');
        });
    </script>
</body>
</html>
